# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email
RESEND_API_KEY=

# SMS / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
NEXT_PUBLIC_APP_URL=

# Account invitations (Stage 2.2c)
# Shared secret required on every call to /api/internal/invitations/sweep-expired.
# Set only in the scheduler's (cron job's) environment, never exposed to the browser.
# The route fails closed (rejects all requests) if this is unset.
INTERNAL_CRON_SECRET=
# Dev-only, default-off. When 'true', /api/admin/invitations/resend includes
# the raw invite link in its JSON response (no mail provider is configured
# yet -- see docs/STAGE-2-1A-REVISED-DESIGN-V2.md). Must remain unset in
# production; the link is never logged or persisted regardless of this flag.
ALLOW_DEV_INVITE_LINK_DISPLAY=
